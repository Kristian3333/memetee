{
  "permissions": {
    "allow": [
      "Bash(python3:*)",
      "Bash(pytest:*)",
      "Bash(uv run:*)",
      "Bash(npm:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Read",
      "Write",
      "Edit"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/secrets*)",
      "Read(**/*credential*)",
      "Read(**/*private_key*)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude Code' 'Agent needs attention' 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
